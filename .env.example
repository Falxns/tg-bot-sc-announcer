TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_IDS=-1001234567890
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=123456789012345678
# Dev bot on prod guild: register slash commands while running, clear on graceful shutdown
# (type q + Enter in terminal, or SIGINT — remapped Ctrl/arrow layouts often skip Ctrl+C)
# DISCORD_DEV_MODE=1
POLL_INTERVAL_MS=300000
# AUTHOR_REQUEST_DELAY_MS=1000
# TELEGRAM_SEND_DELAY_MS=500
# On Render/PaaS use upstash (file backend resets on every deploy/restart):
# STATE_BACKEND=upstash
# UPSTASH_REDIS_REST_URL=https://<instance>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<upstash_rest_token>
# UPSTASH_STATE_KEY=tg-bot-sc-announcer:state
# Local dev default:
# STATE_BACKEND=file
# LAST_SEEN_STATE_FILE=last-seen-posts.json
# POSTS_PER_AUTHOR=5
# MAX_SNIPPET_LEN=1000
# LOG_LEVEL=info
# SKIP_SEND_POST_OLDER_THAN_MS=3600000
# ADMIN_USER_IDS=123456789
# POST_MENTION_MAX_PER_POST=5
# POST_MENTION_BODY_PLAIN_MAX=1200
# POST_MENTION_FETCH_DELAY_MS=250
# QUOTE_POST_MENTION_MAX=20
# TELEGRAM_EXPANDABLE_BLOCKQUOTES=1
# DISCORD_ADMIN_ROLE_IDS=111111111111111111,222222222222222222
# DISCORD_MODERATOR_ROLE_IDS=333333333333333333,444444444444444444
# DISCORD_ROLE_PANEL_CHANNEL_ID=444444444444444444
# DISCORD_BLOCK_INVITE_LINKS_GLOBAL=1
# DISCORD_INVITE_ALLOWED_ROLE_IDS=555555555555555555
# DISCORD_WARNING_MESSAGE_TTL_MS=30000
# Unified timeout ladder (comma-separated ms): 1h, 6h, 12h, 1d, 3d, 7d
# DISCORD_TIMEOUT_LADDER_MS=3600000,21600000,43200000,86400000,259200000,604800000
# DISCORD_WARNINGS_BEFORE_TIMEOUT=3
# First major automod hit uses at least this ladder step (default 3 = 1 day)
# DISCORD_MAJOR_MIN_LADDER_STEP=3
# DISCORD_MODERATION_DECAY_MS=259200000
# Per-mod daily cap on /mute + /strike + /ban (UTC day; 0 = off). Bypass: DISCORD_ADMIN_ROLE_IDS
# DISCORD_MODERATION_DAILY_QUOTA=30
# DISCORD_MODERATION_LOG_CHANNEL_ID=666666666666666666
# Optional: one-line staff digest (mod commands, role creates, creator posts)
# DISCORD_MODERATION_STAFF_SUMMARY_CHANNEL_ID=999999999999999999
# Staff role digests: create / assign / remove — audit-log executor must have one of these roles (View Audit Log)
# DISCORD_STAFF_SUMMARY_ROLE_CREATE_TRACKED_ROLE_IDS=111111111111111111
# DISCORD_STAFF_SUMMARY_ROLE_AUDIT_DELAY_MS=1000
# DISCORD_STAFF_SUMMARY_ROLE_CREATE_NAME_WAIT_MS=60000
# DISCORD_STAFF_SUMMARY_ROLE_CHANGE_BATCH_MS=300000
# Creator posts: channel IDs (top-level messages only, not threads), author role IDs, cooldown between digests per author+channel
# DISCORD_STAFF_SUMMARY_CREATOR_CHANNEL_IDS=123456789012345679,123456789012345680
# DISCORD_STAFF_SUMMARY_CREATOR_ROLE_IDS=222222222222222222
# DISCORD_STAFF_SUMMARY_CREATOR_COOLDOWN_MS=1800000
# Self-delete review: cache media/URL in RAM (1h); post to review channel only when author deletes (View Audit Log)
# DISCORD_MESSAGE_REVIEW_CHANNEL_ID=123456789012345681
# DISCORD_MESSAGE_REVIEW_SOURCE_CHANNEL_IDS=123456789012345679
# DISCORD_MESSAGE_REVIEW_CACHE_TTL_MS=3600000
# DISCORD_MESSAGE_REVIEW_MAX_CACHE_ENTRIES=5000
# DISCORD_MESSAGE_REVIEW_BYPASS_ROLE_IDS=111111111111111111
# DISCORD_MESSAGE_REVIEW_INCLUDE_URLS=1
# DISCORD_MESSAGE_REVIEW_MAX_ATTACHMENT_MB=8
# DISCORD_MESSAGE_REVIEW_AUDIT_DELAY_MS=2000
# Optional: block non-invite http(s) URLs whose host matches (comma list or JSON array of hosts)
# DISCORD_EXTERNAL_LINK_DOMAIN_BLACKLIST=bad.example.com,tracker.example.org
# Comma-separated channel or thread IDs: same author + hybrid duplicate match vs immediate previous (strict normalize, skeleton+length, or long-text similarity; one messages.fetch per check; needs Read Message History)
# DISCORD_SPAM_FILTER_CHANNEL_IDS=777777777777777777,888888888888888888
# Per-channel overrides: crossAuthor = any author, cooldownMs = duplicate window (default 6h when crossAuthor is true). Keys are auto-enabled for spam filter (no need to duplicate in DISCORD_SPAM_FILTER_CHANNEL_IDS). Fingerprints persist via existing saveState only (no extra write per message).
# DISCORD_SPAM_FILTER_CHANNEL_OPTIONS_JSON={"888888888888888888":{"crossAuthor":true,"cooldownMs":21600000}}
# DISCORD_SPAM_FILTER_MAX_FINGERPRINTS_PER_SCOPE=200
# Per-channel JSON: blockInviteLinks, allowDiscordInvites, inviteViolationSeverity (minor|major),
# blockVideos/blockImages/blockText + mediaViolationSeverity, blockedKeywords + keywordViolationSeverity,
# allowInviteRoleIds, channelPresetId (channel-purpose DM text), rulePresetId (optional server rule line for automod in this channel)
# DISCORD_CHANNEL_POLICIES_JSON={"123456789012345679":{"blockText":true,"channelPresetId":"vidos","rulePresetId":"rule_offtopic","mediaViolationSeverity":"minor"}}
# Preset id → channel snowflake for clickable #channel in reason text (/mute /strike /ban + automod)
# DISCORD_MODERATION_CHANNEL_PRESET_CHANNEL_IDS_JSON={"vidos":"123456789012345679","streamy":"123456789012345680"}
# Temporary voice (join-to-create hub + owner panel). Setup: docs/DISCORD_VOICE_SETUP.md
# DISCORD_VOICE_ENABLED=1
# DISCORD_VOICE_HUB_CHANNEL_ID=123456789012345678
# DISCORD_VOICE_TEMP_CATEGORY_ID=123456789012345679
# DISCORD_VOICE_PANEL_CHANNEL_ID=123456789012345680
# Optional: HTTPS URL for panel legend image (default: bundled assets/discord/voice-panel-legend.png)
# DISCORD_VOICE_PANEL_IMAGE_URL=https://example.com/voice-panel-legend.png
# Custom server emojis for panel buttons (upload assets/discord/emojis/*.png first)
# DISCORD_VOICE_BUTTON_EMOJIS_JSON={"name":{"id":"123","name":"voice_name"},...}
# DISCORD_VOICE_DEFAULT_NAME=Комната {user}
# DISCORD_VOICE_EMPTY_DELETE_MS=60000
# DISCORD_VOICE_MAX_CHANNELS_PER_USER=1
# Clan roles (plain-text +клан / -клан / !создать in rules thread; /clanpanel posts help)
# DISCORD_CLAN_ENABLED=1
# DISCORD_CLAN_LEADER_ROLE_ID=123456789012345678
# Anchor role: new clan roles are created directly above this role in the list (bot role must be higher)
# DISCORD_CLAN_ROLE_POSITION_ABOVE_ROLE_ID=123456789012345677
# Clan chat channel (#чат-кланов): new clan roles get Send Messages allow overwrite (bot needs Manage Roles / «Управление правами»)
# DISCORD_CLAN_CHAT_CHANNEL_ID=123456789012345676
# Recruitment channel (#набор-в-кланы): linked from /clanpanel header
# DISCORD_CLAN_RECRUIT_CHANNEL_ID=123456789012345684
# Optional channel mention in /clanpanel header («Подробнее… читайте в #…»)
# DISCORD_CLAN_HELP_CHANNEL_ID=123456789012345682
# Parent rules post — grant requests and plain-text commands go in its public thread
# DISCORD_CLAN_RULES_MESSAGE_ID=123456789012345679
# Extra role IDs excluded from clan role discovery (mods/admin/staff-summary creator roles are always excluded too)
# DISCORD_CLAN_ROLE_EXCLUDE_IDS=111111111111111111,222222222222222222
# DISCORD_CLAN_ROLE_NAME_PATTERN=^.{2,}$
# Roster size for !создать block (line 4+ @mentions)
# DISCORD_CLAN_ROSTER_MIN=15
# DISCORD_CLAN_ROSTER_MAX=35
# Max clan roles per member (default 1; 0 = unlimited). Leader meta-role is separate.
# DISCORD_CLAN_MAX_ROLES_PER_MEMBER=1
# Mod queue channel for new-clan Принять / Отклонить review
# DISCORD_CLAN_CREATE_REVIEW_CHANNEL_ID=123456789012345680
# User notifications for clan request outcomes (#bot-notifications); pending embeds are removed from the rules thread on resolve
# DISCORD_CLAN_NOTIFICATIONS_CHANNEL_ID=123456789012345683
# Optional override for clan audit lines (falls back to DISCORD_MODERATION_LOG_CHANNEL_ID)
# DISCORD_CLAN_STAFF_LOG_CHANNEL_ID=123456789012345681
# Min members with clan role before auto-purge grace (default 10)
# DISCORD_CLAN_ACTIVE_MIN_MEMBERS=10
# Days to fix understaffed / leaderless clans before role deletion (default 3)
# DISCORD_CLAN_ENFORCEMENT_GRACE_DAYS=3
# Clan enforcement check interval ms (default 86400000 = 24h)
# DISCORD_CLAN_ENFORCEMENT_CHECK_MS=86400000
# Leader clan color change cooldown in days (default 7; mods bypass)
# DISCORD_CLAN_COLOR_CHANGE_COOLDOWN_DAYS=7
# Color preset labels for !создать line 3 (JSON override; default built-in Russian presets)
# DISCORD_CLAN_COLOR_PRESETS_JSON=[{"id":"red","label":"Красный","hex":15158332}]
