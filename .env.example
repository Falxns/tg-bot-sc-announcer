TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_IDS=-1001234567890
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=123456789012345678
POLL_INTERVAL_MS=300000
# AUTHOR_REQUEST_DELAY_MS=1000
# TELEGRAM_SEND_DELAY_MS=500
# On Render/PaaS use upstash (file backend resets on every deploy/restart):
# STATE_BACKEND=upstash
# UPSTASH_REDIS_REST_URL=https://<instance>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<upstash_rest_token>
# UPSTASH_STATE_KEY=tg-bot-sc-announcer:state
# Local dev default:
# STATE_BACKEND=file
# LAST_SEEN_STATE_FILE=last-seen-posts.json
# POSTS_PER_AUTHOR=5
# MAX_SNIPPET_LEN=1000
# LOG_LEVEL=info
# SKIP_SEND_POST_OLDER_THAN_MS=3600000
# ADMIN_USER_IDS=123456789
# POST_MENTION_MAX_PER_POST=5
# POST_MENTION_BODY_PLAIN_MAX=1200
# POST_MENTION_FETCH_DELAY_MS=250
# QUOTE_POST_MENTION_MAX=20
# TELEGRAM_EXPANDABLE_BLOCKQUOTES=1
# DISCORD_ADMIN_ROLE_IDS=111111111111111111,222222222222222222
# DISCORD_ROLE_PANEL_CHANNEL_ID=444444444444444444
# DISCORD_BLOCK_INVITE_LINKS_GLOBAL=1
# DISCORD_INVITE_ALLOWED_ROLE_IDS=555555555555555555
# DISCORD_WARNING_MESSAGE_TTL_MS=12000
# Minor / major mute ladders (comma-separated milliseconds)
# DISCORD_MINOR_TIMEOUT_LADDER_MS=3600000,21600000,43200000,86400000
# DISCORD_WARNINGS_BEFORE_TIMEOUT=3
# DISCORD_MAJOR_TIMEOUT_LADDER_MS=86400000,259200000,604800000
# DISCORD_MODERATION_DECAY_MS=259200000
# DISCORD_MODERATION_LOG_CHANNEL_ID=666666666666666666
# Optional: one-line staff digest for manual /mute /unmute /warn /unwarn /ban /unban (links to messages in DISCORD_MODERATION_LOG_CHANNEL_ID)
# DISCORD_MODERATION_STAFF_SUMMARY_CHANNEL_ID=999999999999999999
# Optional: block non-invite http(s) URLs whose host matches (comma list or JSON array of hosts)
# DISCORD_EXTERNAL_LINK_DOMAIN_BLACKLIST=bad.example.com,tracker.example.org
# Comma-separated channel or thread IDs: same author + hybrid duplicate match vs immediate previous (strict normalize, skeleton+length, or long-text similarity; one messages.fetch per check; needs Read Message History)
# DISCORD_SPAM_FILTER_CHANNEL_IDS=777777777777777777,888888888888888888
# Per-channel JSON: blockInviteLinks, allowDiscordInvites, inviteViolationSeverity (minor|major),
# blockVideos/blockImages/blockText + mediaViolationSeverity, blockedKeywords + keywordViolationSeverity,
# allowInviteRoleIds, reasonPresetId (e.g. "vidos" for channel-purpose automod/staff preset text)
# DISCORD_CHANNEL_POLICIES_JSON={"123456789012345679":{"blockText":true,"reasonPresetId":"vidos","mediaViolationSeverity":"minor"}}
# Preset id → channel snowflake for clickable #channel in reason text (/mute /warn /ban + automod)
# DISCORD_MODERATION_REASON_CHANNEL_IDS_JSON={"vidos":"123456789012345679","streamy":"123456789012345680"}
